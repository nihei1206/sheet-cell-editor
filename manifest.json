{
    "manifest_version": 3,
    "name": "Sheet Cell Editor",
    "version": "1.0",
    "description": "A side panel editor for comfortably inputting long text in Google Sheets",
    "permissions": [
        "sidePanel",
        "activeTab",
        "clipboardWrite"
    ],
    "host_permissions": [
        "https://docs.google.com/spreadsheets/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://docs.google.com/spreadsheets/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "action": {
        "default_title": "Open Editor"
    },
    "side_panel": {
        "default_path": "sidepanel.html"
    }
}